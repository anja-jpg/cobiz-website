{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/groeirapport/layout,_N_T_/groeirapport/page,_N_T_/groeirapport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/groeirapport/__PAGE__",
    "/groeirapport",
    "/_index",
    "/_head"
  ]
}